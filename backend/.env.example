PORT=5001
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxx.mongodb.net/flexhire
JWT_SECRET=<generate-a-64-char-hex-string>
CLIENT_URL=http://localhost:5173

# Razorpay (test mode)
RAZORPAY_KEY_ID=<from-razorpay-dashboard>
RAZORPAY_KEY_SECRET=<from-razorpay-dashboard>
RAZORPAY_WEBHOOK_SECRET=<from-razorpay-dashboard-webhook-settings>

# Cloudinary
CLOUDINARY_CLOUD_NAME=<from-cloudinary-dashboard>
CLOUDINARY_API_KEY=<from-cloudinary-dashboard>
CLOUDINARY_API_SECRET=<from-cloudinary-dashboard>

# Gmail (requires App Password — 2FA must be enabled on account)
GMAIL_USER=<your@gmail.com>
GMAIL_APP_PASSWORD=<16-char-app-password>

# Upstash Redis (ioredis TLS URL — Dashboard → Redis → Connect → ioredis)
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379
